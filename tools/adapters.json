{
  "schemaVersion": "2.0.0",
  "description": "Multi-tool adapter registry. The canonical source remains skills/, rules/AGENTS.md, and docs/_templates/. Adapter outputs are generated delivery targets only.",
  "sourceOfTruth": {
    "rules": "rules/AGENTS.md",
    "skills": "skills/",
    "docs": "docs/_templates/"
  },
  "statusLegend": {
    "verified": "Rule path is backed by official documentation or existing local verification.",
    "experimental": "Likely supported, but needs live verification in the target tool/version.",
    "pending-verification": "Do not deploy by default. Path or behavior is not yet reliable enough."
  },
  "deployDefaults": {
    "toolSelector": "verified-only",
    "rulesStrategy": "copy",
    "skillsStrategy": "symlink",
    "backupExisting": false,
    "createMissingDirs": true
  },
  "tools": {
    "codex": {
      "name": "Codex",
      "vendor": "OpenAI",
      "tier": "P0",
      "status": "verified",
      "aliases": ["openai-codex"],
      "ruleTargets": [
        {
          "path": "AGENTS.md",
          "format": "agents-md",
          "source": "rules/AGENTS.md",
          "mode": "copy"
        }
      ],
      "skills": {
        "path": ".agents/skills",
        "mode": "symlink",
        "layout": "layered",
        "status": "verified"
      },
      "notes": "AGENTS.md is the primary portable entrypoint. Local .agents/ is an adapter output, not a source directory."
    },
    "claude": {
      "name": "Claude Code",
      "vendor": "Anthropic",
      "tier": "P0",
      "status": "verified",
      "aliases": ["claude-code"],
      "ruleTargets": [
        {
          "path": "CLAUDE.md",
          "format": "markdown",
          "source": "rules/AGENTS.md",
          "mode": "copy"
        }
      ],
      "skills": {
        "path": ".claude/skills",
        "mode": "symlink",
        "layout": "layered",
        "status": "verified"
      }
    },
    "trae": {
      "name": "Trae",
      "vendor": "ByteDance",
      "tier": "P0",
      "status": "verified",
      "aliases": ["trae-cn"],
      "ruleTargets": [
        {
          "path": ".trae/rules/project_rules.md",
          "format": "markdown",
          "source": "rules/AGENTS.md",
          "mode": "copy"
        }
      ],
      "skills": {
        "path": ".trae/skills",
        "mode": "symlink",
        "layout": "layered",
        "status": "experimental"
      },
      "notes": "Project rules are verified. Skill directory behavior may vary by Trae version."
    },
    "trae-solo": {
      "name": "Trae Solo",
      "vendor": "ByteDance",
      "tier": "P3",
      "status": "pending-verification",
      "aliases": ["trae-work"],
      "ruleTargets": [
        {
          "path": ".trae/rules/project_rules.md",
          "format": "markdown",
          "source": "rules/AGENTS.md",
          "mode": "copy"
        }
      ],
      "skills": {
        "path": ".trae/skills",
        "mode": "symlink",
        "layout": "layered",
        "status": "pending-verification"
      },
      "notes": "Keep separate from Trae IDE until Solo/Work rule loading is verified."
    },
    "qoder": {
      "name": "Qoder",
      "vendor": "Qoder",
      "tier": "P0",
      "status": "verified",
      "aliases": ["qoder-cn"],
      "ruleTargets": [
        {
          "path": ".qoder/rules/enterprise-ai-dev-os.md",
          "format": "markdown",
          "source": "rules/AGENTS.md",
          "mode": "copy"
        }
      ],
      "skills": {
        "path": ".qoder/skills",
        "mode": "symlink",
        "layout": "flat",
        "status": "verified"
      },
      "notes": "Qoder project rules are directory based: .qoder/rules/. Project skills use .qoder/skills/{skill-name}/SKILL.md, so deployment flattens the canonical layered skill tree."
    },
    "cursor": {
      "name": "Cursor",
      "vendor": "Anysphere",
      "tier": "P1",
      "status": "verified",
      "aliases": [],
      "ruleTargets": [
        {
          "path": ".cursor/rules/enterprise-ai-dev-os.mdc",
          "format": "cursor-mdc",
          "source": "rules/AGENTS.md",
          "mode": "copy"
        },
        {
          "path": ".cursorrules",
          "format": "markdown",
          "source": "rules/AGENTS.md",
          "mode": "copy",
          "legacy": true
        }
      ],
      "skills": {
        "path": ".cursor/skills",
        "mode": "symlink",
        "layout": "layered",
        "status": "experimental"
      },
      "notes": "Use .cursor/rules/*.mdc as the primary target. .cursorrules is legacy fallback."
    },
    "copilot": {
      "name": "GitHub Copilot",
      "vendor": "GitHub",
      "tier": "P1",
      "status": "verified",
      "aliases": ["vscode-copilot", "vs-code-copilot"],
      "ruleTargets": [
        {
          "path": ".github/copilot-instructions.md",
          "format": "copilot",
          "source": "rules/AGENTS.md",
          "mode": "copy"
        },
        {
          "path": ".github/instructions/enterprise-ai-dev-os.instructions.md",
          "format": "copilot-path",
          "source": "rules/AGENTS.md",
          "mode": "copy"
        }
      ],
      "skills": {
        "path": null,
        "mode": "none",
        "status": "not-supported"
      },
      "notes": "Copilot consumes custom instructions, not the SKILL.md directory model."
