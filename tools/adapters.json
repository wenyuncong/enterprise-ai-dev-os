  "skill_categories": ["core", "governance", "tech", "platform"],

  "deploy_options": {
    "rules_strategy": "copy",
    "_rules_strategy_note": "Rules files are COPIED (not symlinked) because some tools modify them. Skills are symlinked because they are read-only.",
    "backup_existing": false,
    "create_missing_dirs": true,
    "require_admin": false,
    "_require_admin_note": "Windows symlinks may require admin or Developer Mode. If unavailable, falls back to directory junctions or copy."
  }
