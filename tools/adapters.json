    },
    "qoder": {
      "name": "Qoder / Qoder CN",
      "skills_dir": ".qoder/skills",
      "rules_file": ".qoder/rules.md",
      "rules_dir": null,
      "link_strategy": "symlink",
      "verified": true
    },
    "codebuddy": {
      "name": "CodeBuddy (腾讯)",
      "skills_dir": ".codebuddy/skills",
      "rules_file": ".codebuddy/rules.md",
      "rules_dir": null,
      "link_strategy": "symlink",
      "verified": true
    },
    "claude": {
      "name": "Claude Code (Anthropic)",
      "skills_dir": ".claude/skills",
      "rules_file": "CLAUDE.md",
      "rules_dir": null,
      "link_strategy": "symlink",
      "verified": true
